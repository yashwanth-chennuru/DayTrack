{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:webview:allow-set-webview-zoom",
    "deep-link:default",
    "shell:default"
  ]
}