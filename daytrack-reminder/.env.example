# Firebase (for reading Firestore)
# Your Firebase project ID (e.g. my-project-id)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Your Firebase User UID
# Find this in Firebase Console -> Authentication -> Users
FIREBASE_USER_UID=your-firebase-user-uid

# Matrix Setup
# Get this by logging into your bot account and calling the Matrix /login API
MATRIX_ACCESS_TOKEN=your-matrix-access-token

# The internal room ID of the Matrix room to send reminders to
# Looks like: !abcXYZ123:matrix.org
# Find it in Element -> Room Settings -> Advanced -> Internal Room ID
MATRIX_ROOM_ID=!your-room-id:matrix.org
